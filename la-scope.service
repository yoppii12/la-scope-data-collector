[Unit]
Description=LA-Scope Dataset Collector
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/la-scope-data-collector
ExecStart=/home/pi/la-scope-data-collector/venv/bin/uvicorn backend.app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
